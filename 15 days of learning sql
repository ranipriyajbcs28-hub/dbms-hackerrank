SELECT 
    sub_date,
    (SELECT COUNT(DISTINCT hacker_id) 
     FROM Submissions s2 
     WHERE s2.submission_date = sub_date 
     AND (SELECT COUNT(DISTINCT s3.submission_date) 
          FROM Submissions s3 
          WHERE s3.hacker_id = s2.hacker_id 
          AND s3.submission_date < sub_date) = DATEDIFF(sub_date, '2016-03-01')),
    (SELECT hacker_id FROM Submissions s2 
     WHERE s2.submission_date = sub_date 
     GROUP BY hacker_id 
     ORDER BY COUNT(submission_id) DESC, hacker_id ASC LIMIT 1) as top_hacker,
    (SELECT name FROM Hackers WHERE hacker_id = top_hacker)
FROM (SELECT DISTINCT submission_date as sub_date FROM Submissions) s1
ORDER BY sub_date;
